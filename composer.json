{
    "name": "novacore/framework",
    "description": "NovaCore PHP Framework for IoT, SaaS and Enterprise Applications",
    "type": "project",
    "license": "MIT",

    "require": {
        "php": "^8.4",
        "vlucas/phpdotenv": "^5.6"
    },

    "autoload": {
        "psr-4": {
            "NovaCore\\": "app/",
            "NovaCore\\Console\\": "app/Console/"
        },

        "files": [
            "app/helpers.php"
        ]
    },

    "autoload-dev": {
        "psr-4": {
            "NovaCore\\Tests\\": "tests/"
        }
    },

    "scripts": {
        "test": "php vendor/bin/phpunit"
    }
}